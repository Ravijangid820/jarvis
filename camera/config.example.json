{
  "device_id": "laptop-cam",
  "server": {
    "url": "https://192.168.0.101:5000",
    "events_endpoint": "/events",
    "api_key_file": "config/agent.key",
    "admin_key_file": "config/admin.key",
    "ca_cert": "config/ca.crt"
  },
  "camera": {
    "backend": "auto",
    "device": 0,
    "width": 480,
    "height": 360,
    "fps": 8
  },
  "detectors": {
    "motion":   { "enabled": true,  "min_area": 1500, "cooldown_s": 3 },
    "faces":    { "enabled": true,  "interval_s": 5,
                  "detector_model": "models/face_detection_yunet_2023mar.onnx",
                  "embed_model": "models/face_recognition_sface_2021dec.onnx",
                  "score_threshold": 0.9, "recognize_threshold": 0.363 },
    "pose":     { "enabled": false, "interval_s": 3 },
    "gestures": { "enabled": false, "interval_s": 2 }
  }
}
