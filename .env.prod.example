# ==============================================================================
# JARVIS Production Stack Environment Configuration Template
# ==============================================================================
# Copy this file to .env.prod and customize values for your deployment host.
# NEVER commit your actual .env.prod file to version control.
# ==============================================================================

# --- Container Images ---
ORCH_IMAGE=ghcr.io/ravijangid820/jarvis-orchestrator:latest
LLAMA_IMAGE=ghcr.io/ravijangid820/jarvis-llama:latest

# --- Container Interconnection ---
# Internal network address for the LLM inference engine.
# Standard compose setup uses: http://llama:8081/v1/chat/completions
JARVIS_FAST_BRAIN_URL=http://llama:8081/v1/chat/completions

# --- Public Access & CORS ---
# Comma-separated list of allowed web frontend origins (e.g. https://your-domain.example.com)
ALLOWED_ORIGINS=http://localhost:5000

# --- Server Access & Credentials ---
HOST_PORT=5000
ADMIN_USER=admin
ADMIN_PASS=admin

# --- Model Tunables ---
EMBED_MODEL=google/embeddinggemma-300m

# --- Optional Integrations ---
HA_URL=
HA_TOKEN=
HA_ALLOWED_ENTITIES=
