# ---- Python ----
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# ---- Virtual environments ----
.venv
venv/

# ---- Caches (HF model cache lives here after a non-root install; multi-GB) ----
.cache/

# ---- Generated systemd units (install_services.sh DRY_RUN preview) ----
systemd/generated/

# ---- Secrets & runtime config (NEVER commit) ----
# jarvis.json holds the master API key. Commit jarvis.example.json instead.
config/jarvis.json
# Docker env file — holds HF_TOKEN + admin password. Commit .env.example instead.
.env

# ---- TLS keys + certs (generated by src/scripts/setup_tls.sh; NEVER commit) ----
# Each deployment makes its OWN local CA — certs are per-deployment, not source. Devices fetch the
# public CA from their own server (GET /ca.crt or camera/get-ca.*), so nothing here is committed.
tls/
camera/ca.crt
camera/config/ca.crt

# ---- Runtime data (DB w/ password hashes + auth tokens, vectors, logs) ----
memory/
logs/
backups/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ---- Large binaries / vendored builds (rebuild from source; see docs) ----
# Model weights (GGUF, ONNX) — multi-GB, do not version. Ignore the dir CONTENTS (not the dir) so the
# committed models/.keep keeps the folder present and the Docker build's "COPY models/" is always valid.
models/*
!models/.keep
*.gguf
# Pre-downloaded embedding-model cache (baked into the Docker image). Weights stay out of git; the
# .keep preserves the dir so the build's "COPY embed-cache/" is always valid.
embed-cache/*
!embed-cache/.keep
*.onnx
*.bin
# whisper.cpp — vendored upstream, built from source
whisper/
# Piper TTS binary + voices — installed via src/scripts/piper_setup.sh
piper/

# ---- Frontend ----
node_modules/
frontend/node_modules/
frontend/dist/

# ---- Editor / OS / tooling ----
.DS_Store
*.swp
.idea/
# Local Claude Code settings (permissions/MCP allowlist — personal, not source)
.claude/

# Voice-listener API key (mint with manage.py)
config/voice_listener.key
