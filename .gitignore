# ---- Python ----
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# ---- Virtual environments ----
.venv
venv/

# ---- Caches (HF model cache lives here after a non-root install; multi-GB) ----
.cache/

# ---- Generated systemd units (install_services.sh DRY_RUN preview) ----
systemd/generated/

# ---- Secrets & runtime config (NEVER commit) ----
# jarvis.json holds the master API key. Commit jarvis.example.json instead.
config/jarvis.json

# ---- TLS keys + certs (generated by src/scripts/setup_tls.sh; NEVER commit) ----
# Each deployment makes its OWN local CA — certs are per-deployment, not source. Devices fetch the
# public CA from their own server (GET /ca.crt or camera/get-ca.*), so nothing here is committed.
tls/
camera/ca.crt
camera/config/ca.crt

# ---- Runtime data (DB w/ password hashes + auth tokens, vectors, logs) ----
memory/
logs/
backups/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ---- Large binaries / vendored builds (rebuild from source; see docs) ----
# Model weights (GGUF, ONNX) — multi-GB, do not version
models/
*.gguf
*.onnx
*.bin
# whisper.cpp — vendored upstream, built from source
whisper/
# Piper TTS binary + voices — installed via src/scripts/piper_setup.sh
piper/

# ---- Frontend ----
node_modules/
frontend/node_modules/
frontend/dist/

# ---- Editor / OS ----
.DS_Store
*.swp
.idea/

# Voice-listener API key (mint with manage.py)
config/voice_listener.key
