# syntax=docker/dockerfile:1
# COMBINED / all-in-one image — ONE self-contained container built ON TOP OF the OFFICIAL llama.cpp
# server image. We do NOT compile llama.cpp: the base already ships a prebuilt, all-CPU-variant
# `llama-server` at /app/llama-server (runs on AVX / AVX2 / AVX-512, auto-detected). We just layer the
# orchestrator + baked LLM & embedding on top and set the default entrypoint to all-in-one, so a plain
# `docker run` — or a Proxmox VE 9.1 OCI container (which runs the image's *default* entrypoint) — starts
# BOTH services with no override. New llama.cpp release = bump LLAMA_IMAGE, no build to maintain.

# GLOBAL build arg — must be declared BEFORE the first FROM to be usable in the runtime-stage FROM below.
# Pin to a specific tag (e.g. ghcr.io/ggml-org/llama.cpp:server-b<NNNN>) for reproducible production
# builds; :server is the floating latest server build.
ARG LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server

# --- Stage 1: build the React frontend ---
FROM node:20-slim AS web
WORKDIR /web
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# --- Stage 2: resolve/bake the default model (from ./models, else download + verify) ---
FROM debian:12-slim AS model
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
# Defaults = the pinned, SHA-verified model (same as download_models.sh) so a bare
# `docker build -f Dockerfile.combined .` with NO build-args still produces a working image.
# Override the pair together to bake a different model.
ARG LLM_GGUF_URL=https://huggingface.co/unsloth/Qwen3.5-2B-GGUF/resolve/main/Qwen3.5-2B-Q4_K_M.gguf
ARG LLM_GGUF_SHA256=aaf42c8b7c3cab2bf3d69c355048d4a0ee9973d48f16c731c0520ee914699223
ARG DEFAULT_MODEL=Qwen3.5-2B-Q4_K_M.gguf
COPY models/ /staged/
RUN set -eu; mkdir -p /out; \
    existing="$(find /staged -name "$DEFAULT_MODEL" -type f | head -n1 || true)"; \
    [ -z "$existing" ] && existing="$(find /staged -name '*.gguf' -type f | sort | head -n1 || true)"; \
    if [ -n "$existing" ]; then echo "Baking model from build context: $existing"; cp "$existing" /out/; \
    elif [ -n "$LLM_GGUF_URL" ]; then \
      echo "No model in ./models — downloading from LLM_GGUF_URL"; \
      case "$LLM_GGUF_URL" in https://*) ;; *) echo "WARN: LLM_GGUF_URL is not https:// — could be tampered in transit";; esac; \
      fn="$(basename "$LLM_GGUF_URL")"; case "$fn" in *.gguf) ;; *) fn=model.gguf;; esac; \
      curl -L --fail --retry 5 --retry-all-errors --retry-delay 5 -C - -o "/out/$fn" "$LLM_GGUF_URL"; \
      if [ -n "$LLM_GGUF_SHA256" ]; then echo "${LLM_GGUF_SHA256}  /out/$fn" | sha256sum -c -; \
      else echo "WARN: LLM_GGUF_SHA256 not set — skipping integrity check"; fi; \
    else echo "NOTE: no model in ./models and no LLM_GGUF_URL — image ships without a baked default."; fi

# --- Embedding: torch-free ONNX bundle (full ST pipeline in one graph) — public, SHA-256-pinned,
#     NO HuggingFace token. Converted from the official google weights + verified cosine 1.000000
#     vs torch (src/scripts/export_embed_onnx.py); hosted on the project owner's HF repo.
FROM debian:12-slim AS embed
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
ARG EMBED_ONNX_BASE=https://huggingface.co/Ravijangid820/embeddinggemma-300m-onnx/resolve/main
RUN set -eu; mkdir -p /out; cd /out; \
    dl() { curl -L --fail --retry 5 --retry-all-errors --retry-delay 5 -C - -o "$1" "${EMBED_ONNX_BASE}/$1" \
           && echo "$2  $1" | sha256sum -c -; }; \
    dl model.onnx            39a1f3039ed66e39c5174469dc5ce0417ef57993590170164b18beb8254de2d0; \
    dl model.onnx.data       1d5fb11500ae836f3a42efc3c7123076416d9e527ae479d19d940a3c784f0035; \
    dl tokenizer.json        3f797e7e336523ba3845bf09a648fd87c14bf357f26beb091d8284dff48ea27c; \
    dl tokenizer_config.json 7f4973d11e065de3097b85319ef7c43e143aa7f1df619ebe1056f81b8de97edb; \
    dl meta.json             b149d450b0bd383a207b3328cb9dd093082077c84eb4e178418a2db0f4f2dccf

# --- Stage 3: runtime = official llama.cpp server + our orchestrator ---
# LLAMA_IMAGE is the global arg declared at the top of this file (before the first FROM).
FROM ${LLAMA_IMAGE}
# Base = ubuntu 24.04 with /app/llama-server + its ggml libs (in /app), libgomp1 + curl already present.
# Our app lives alongside at /app (JARVIS_HOME=/app), coexisting with the llama-server binary + libs —
# no filename clashes. llama-server stays put; all-in-one.sh runs /app/llama-server on loopback.
ENV JARVIS_HOME=/app \
    JARVIS_CONFIG=/app/config/jarvis.json \
    PYTHONUNBUFFERED=1 \
    LLAMA_ARG_HOST=127.0.0.1
# Runtime libs for onnxruntime + the Piper fetch. (libgomp1 already in the base.)
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl tar gzip libstdc++6 \
    && rm -rf /var/lib/apt/lists/*
# uv (pinned copy, no curl|sh). No system Python 3.13 on ubuntu 24.04, so let uv fetch a standalone one.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev
# Torch-free embedding bundle — at /opt so a /app/models bind-mount can never shadow it.
COPY --from=embed /out /opt/jarvis/embed_onnx
ENV EMBED_ONNX_DIR=/opt/jarvis/embed_onnx
COPY src/ ./src/
COPY config/ ./config/
COPY licenses/ ./licenses/
COPY --from=web /web/dist ./frontend/dist
# Baked default model — kept at /opt so a ./models bind-mount never hides it.
COPY --from=model /out/ /opt/jarvis/models/
RUN sed -i 's/\r$//' src/scripts/*.sh; \
    bash src/scripts/piper_setup.sh || echo "WARN: piper_setup failed — TTS unavailable until fixed"
COPY docker/ ./docker/
RUN sed -i 's/\r$//' docker/*.sh && chmod +x docker/*.sh
EXPOSE 5000
# Default = BOTH services (the whole point of this image).
ENTRYPOINT ["/app/docker/all-in-one.sh"]
