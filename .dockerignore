# Keep the build context small + reproducible. Anything produced at build/run time, mounted as a
# volume, or host-specific is excluded.
.git
.github
.claude
.venv
**/__pycache__
**/*.pyc
node_modules
frontend/node_modules
frontend/dist
# NOTE: models/ is intentionally NOT ignored — the GGUF you put there is baked into the image.
# ...but the local ONNX bundle is (the image fetches its own pinned copy from HF).
models/embed_onnx
whisper
piper
memory
backups
logs
tls
.cache
config/jarvis.json
docs
tests
*.md
