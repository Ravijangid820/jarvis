# syntax=docker/dockerfile:1
# SLIM ORCHESTRATOR image for the two-image (production) split: FastAPI API + built React UI +
# embeddings (memory) + Piper TTS. It does NOT contain llama-server or the LLM GGUF — those live in a
# separate `llama` service (the official ghcr.io/ggml-org/llama.cpp:server image). The orchestrator
# reaches the LLM over the network at http://llama:8081 (from config/jarvis.docker.json). This is the
# default two-service `docker-compose.yml`.
#
# Published as ghcr.io/<owner>/jarvis-orchestrator. For a single self-contained container instead, see
# Dockerfile.combined (jarvis-combined).

# --- Stage 1: build the React frontend ---
FROM node:20-slim AS web
WORKDIR /web
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# --- Embedding: torch-free ONNX bundle (full ST pipeline in one graph) — public, SHA-256-pinned,
#     NO HuggingFace token. Converted from the official google weights + verified cosine 1.000000
#     vs torch (src/scripts/export_embed_onnx.py); hosted on the project owner's HF repo.
FROM debian:12-slim AS embed
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
ARG EMBED_ONNX_BASE=https://huggingface.co/Ravijangid820/embeddinggemma-300m-onnx/resolve/main
RUN set -eu; mkdir -p /out; cd /out; \
    dl() { curl -L --fail --retry 5 --retry-all-errors --retry-delay 5 -C - -o "$1" "${EMBED_ONNX_BASE}/$1" \
           && echo "$2  $1" | sha256sum -c -; }; \
    dl model.onnx            39a1f3039ed66e39c5174469dc5ce0417ef57993590170164b18beb8254de2d0; \
    dl model.onnx.data       1d5fb11500ae836f3a42efc3c7123076416d9e527ae479d19d940a3c784f0035; \
    dl tokenizer.json        3f797e7e336523ba3845bf09a648fd87c14bf357f26beb091d8284dff48ea27c; \
    dl tokenizer_config.json 7f4973d11e065de3097b85319ef7c43e143aa7f1df619ebe1056f81b8de97edb; \
    dl meta.json             b149d450b0bd383a207b3328cb9dd093082077c84eb4e178418a2db0f4f2dccf

# --- Stage 3: Python runtime (orchestrator) ---
FROM python:3.13-slim AS app
ENV JARVIS_HOME=/app \
    JARVIS_CONFIG=/app/config/jarvis.json \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl tar gzip libgomp1 libstdc++6 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
WORKDIR /app
# Python deps first (layer cache).
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev
# Torch-free embedding bundle — at /opt so a /app/models bind-mount can never shadow it.
COPY --from=embed /out /opt/jarvis/embed_onnx
ENV EMBED_ONNX_DIR=/opt/jarvis/embed_onnx
# App + config + license notices + built UI.
COPY src/ ./src/
COPY config/ ./config/
COPY licenses/ ./licenses/
COPY --from=web /web/dist ./frontend/dist
# Piper TTS (normalize CRLF from Windows checkouts first).
RUN sed -i 's/\r$//' src/scripts/*.sh; \
    bash src/scripts/piper_setup.sh || echo "WARN: piper_setup failed — TTS will be unavailable until fixed"
COPY docker/ ./docker/
RUN sed -i 's/\r$//' docker/*.sh && chmod +x docker/*.sh
EXPOSE 5000
ENTRYPOINT ["/app/docker/entrypoint.sh"]
