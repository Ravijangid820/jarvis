# OPTIONAL — every value here has a default, so the stack runs with NO .env at all.
# To use it:   cp .env.example .env   then edit the values you want to change.
# It is honored by BOTH deployment paths:
#   • Docker:  docker compose reads ./.env automatically
#   • Repo:    setup.sh / run.sh / setup-server.sh load ./.env too (shell-set variables win)
# Or skip the file and pass values inline:  ADMIN_PASS=secret docker compose up -d
# (.env is git-ignored — never commit real secrets.)

# First-run admin account. Defaults to admin / admin — fine for local use, but INSECURE:
# set ADMIN_PASS for anything reachable beyond your machine.
ADMIN_USER=admin
ADMIN_PASS=admin

# Port the web UI / API is published on (the Docker host's port).
HOST_PORT=5000

# --- Model ---
# A default model is BAKED INTO THE IMAGE — leave LLM_MODEL blank and it just works.
# To use your OWN model instead: put a .gguf in ./models and set LLM_MODEL to its path
# (relative to ./models), e.g. LLM_MODEL=llama3.2-3b/Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLM_MODEL=
# Model source for BUILD-TIME baking: if ./models has no .gguf when you build, the image downloads
# the model from here and verifies the SHA-256. (Also used at runtime to fetch an LLM_MODEL override.)
# Default = Qwen3.5-2B Q4_K_M (unsloth GGUF, public — no token needed). The SHA-256 is verified
# byte-identical to what this project runs. Replace both to bake a different model.
LLM_GGUF_URL=https://huggingface.co/unsloth/Qwen3.5-2B-GGUF/resolve/main/Qwen3.5-2B-Q4_K_M.gguf
LLM_GGUF_SHA256=aaf42c8b7c3cab2bf3d69c355048d4a0ee9973d48f16c731c0520ee914699223
# Context window the LLM server allocates (bigger = more RAM).
LLM_CTX=4096
# llama.cpp CPU threads — match your host's core count.
LLAMA_THREADS=4
# Any extra llama-server flags, e.g. "--top-k 40 --top-p 0.9 --repeat-penalty 1.1 --mlock".
LLAMA_EXTRA_ARGS=

# --- Embedding (memory/RAG) ---
# The embedding runs as a torch-free ONNX bundle (default google/embeddinggemma-300m; public,
# SHA-256-pinned — NO HuggingFace token). A different model needs its own exported bundle
# (src/scripts/export_embed_onnx.py) mounted at EMBED_ONNX_DIR.
# NOTE: changing it requires re-indexing existing memories (different vector space). It's both a
# build arg (what gets baked) and a runtime setting, so set it the same in both if you override.
EMBED_MODEL=google/embeddinggemma-300m

# --- Native (from-source) build options — Docker doesn't compile llama.cpp anymore ---
# llama.cpp release tag for the native build (default: a pinned official release; =master for HEAD).
LLAMA_CPP_REF=
# Native compile parallelism. Default: computed from AVAILABLE RAM (~2 GB/job) — set only to override,
# e.g. BUILD_JOBS=1 on a very small machine.
BUILD_JOBS=
