# Copy to .env, fill in, then: docker compose up -d --build
# (.env is git-ignored — never commit real secrets.)

# HuggingFace token — REQUIRED to download the gated Gemma embedding model on first run.
# Accept the license first: https://huggingface.co/google/embeddinggemma-300m
HF_TOKEN=

# First-run admin account (created on startup if both are set).
ADMIN_USER=admin
ADMIN_PASS=change-me

# Port the web UI / API is published on (the Docker host's port).
HOST_PORT=5000

# --- Model ---
# A default model is BAKED INTO THE IMAGE — leave LLM_MODEL blank and it just works.
# To use your OWN model instead: put a .gguf in ./models and set LLM_MODEL to its path
# (relative to ./models), e.g. LLM_MODEL=llama3.2-3b/Llama-3.2-3B-Instruct-Q4_K_M.gguf
LLM_MODEL=
# Model source for BUILD-TIME baking: if ./models has no .gguf when you build, the image downloads
# the model from here and verifies the SHA-256. (Also used at runtime to fetch an LLM_MODEL override.)
# Use an official https source; setting the SHA-256 is strongly recommended.
LLM_GGUF_URL=
LLM_GGUF_SHA256=
# Context window the LLM server allocates (bigger = more RAM).
LLM_CTX=4096
# llama.cpp CPU threads — match your host's core count.
LLAMA_THREADS=4
# Any extra llama-server flags, e.g. "--top-k 40 --top-p 0.9 --repeat-penalty 1.1 --mlock".
LLAMA_EXTRA_ARGS=

# --- Build-time options (used by `docker compose build`) ---
# Pin the llama.cpp upstream release for a reproducible build (recommended). Unset = upstream HEAD.
LLAMA_CPP_REF=
# CPU baseline for the llama.cpp build: ON = require AVX2 (modern hosts, faster).
# OFF = AVX-only / older CPUs (what the native old-box build uses).
GGML_AVX2=ON
