[Unit]
Description=Jarvis Fast Brain - Qwen3.5-2B LLM Server
After=network.target
Documentation=https://github.com/ggml-org/llama.cpp
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/root/llama.cpp/build/bin/llama-server \
    -m /srv/jarvis/models/qwen3.5_2b/Qwen3.5-2B-Q4_K_M.gguf \
    -c 4096 \
    -t 2 \
    --batch-size 256 \
    --ubatch-size 256 \
    --host 127.0.0.1 \
    --port 8081 \
    --parallel 1 \
    --reasoning off
Restart=on-failure
RestartSec=10
SyslogIdentifier=llama-fast
# Security hardening
# NOTE: ProtectHome is not set because the llama-server binary lives in /root/llama.cpp
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=full
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6
# Resource limits
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
